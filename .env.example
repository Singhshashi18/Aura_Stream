# Django
SECRET_KEY=replace-with-a-strong-secret-key

# Database (PostgreSQL)
POSTGRES_DB=aura_stream
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-realtime-preview
OPENAI_AGENT_MODEL=gpt-4o-mini
OPENAI_REALTIME_URL=

# Frontend websocket config
# If VITE_WS_URL is set, it is used directly (full ws:// or wss:// URL).
# Otherwise frontend builds ws/wss from window.location.protocol + VITE_BACKEND_HOST.
VITE_WS_URL=
VITE_BACKEND_HOST=127.0.0.1:8001

# Realtime debug/noise diagnostics
EMIT_BACKGROUND_NOISE_EVENTS=false
BACKGROUND_NOISE_EVENT_INTERVAL_MS=1000
